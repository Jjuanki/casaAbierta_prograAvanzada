<!--
    Este layout ya NO es el contentView directo de la Activity.
    MainActivity crea el GLSurfaceView por codigo y le agrega ESTE layout
    encima (como overlay) dentro de un FrameLayout, para tener los controles
    de luz (boton on/off + slider del cono), el D-pad de movimiento y el
    boton de recentrar flotando sobre la escena 3D.
  -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- ====== Panel de controles de luz, pegado abajo ======
         Fondo "glassmorphism": rectangulo redondeado semi-transparente con
         borde sutil, en vez del negro plano de antes. -->
    <LinearLayout
        android:id="@+id/lightControlsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_glass_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnToggleLight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:minWidth="160dp"
            android:paddingVertical="10dp"
            android:text="Apagar luz"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_toggle_button"
            android:stateListAnimator="@animator/btn_press_scale"
            android:elevation="4dp"/>

        <TextView
            android:id="@+id/tvSpotAngleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:text="Cono de luz"/>

        <SeekBar
            android:id="@+id/seekSpotAngle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:progressDrawable="@drawable/seekbar_progress"
            android:thumb="@drawable/seekbar_thumb"
            android:splitTrack="false"/>
    </LinearLayout>

    <!-- ====== D-pad de movimiento (flechas) ======
         Panel "glass" independiente, ubicado arriba del panel de luz para
         que nunca se superponga con el slider. 4 botones en cruz: arriba,
         abajo, izquierda y derecha, comodos para el pulgar. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dpadPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_glass_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lightControlsPanel">

        <ImageButton
            android:id="@+id/btnMoveUp"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="14dp"
            android:src="@drawable/ic_arrow_up"
            android:contentDescription="Mover arriba"
            android:background="@drawable/bg_arrow_button"
            android:stateListAnimator="@animator/btn_press_scale"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageButton
            android:id="@+id/btnMoveLeft"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="14dp"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Mover izquierda"
            android:background="@drawable/bg_arrow_button"
            android:stateListAnimator="@animator/btn_press_scale"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnMoveDown"
            app:layout_constraintBottom_toBottomOf="@id/btnMoveDown"/>

        <ImageButton
            android:id="@+id/btnMoveDown"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="14dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_arrow_down"
            android:contentDescription="Mover abajo"
            android:background="@drawable/bg_arrow_button"
            android:stateListAnimator="@animator/btn_press_scale"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="@id/btnMoveUp"
            app:layout_constraintEnd_toEndOf="@id/btnMoveUp"
            app:layout_constraintTop_toBottomOf="@id/btnMoveUp"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageButton
            android:id="@+id/btnMoveRight"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="14dp"
            android:src="@drawable/ic_arrow_right"
            android:contentDescription="Mover derecha"
            android:background="@drawable/bg_arrow_button"
            android:stateListAnimator="@animator/btn_press_scale"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toEndOf="@id/btnMoveDown"
            app:layout_constraintTop_toTopOf="@id/btnMoveDown"
            app:layout_constraintBottom_toBottomOf="@id/btnMoveDown"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ====== Boton flotante: recentra la figura ====== -->
    <Button
        android:id="@+id/btnCenterFigure"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:background="@drawable/bg_center_button"
        android:stateListAnimator="@animator/btn_press_scale"
        android:elevation="4dp"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:text="Centrar figura"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lightControlsPanel"/>

</androidx.constraintlayout.widget.ConstraintLayout>
